{
  "JwtSettings": {
    "SecretKey": "DentalClinic-SaaS-SecretKey-ChangeInProd-Min32Chars!!",
    "Issuer":    "DentalClinicSystem",
    "Audience":  "DentalClinicSystem"
  },

  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173",
    "https://app.nhakhoa.vn"
  ],

  "ReverseProxy": {
    "Routes": {

      "auth-route": {
        "ClusterId":        "dental-cluster",
        "RateLimiterPolicy": "AuthLimit",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },

      "booking-route": {
        "ClusterId":           "dental-cluster",
        "AuthorizationPolicy": "AuthenticatedUser",
        "RateLimiterPolicy":   "BookingLimit",
        "Match": {
          "Path": "/api/booking/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/appointments/{**catch-all}" }
        ]
      },

      "emr-route": {
        "ClusterId":           "dental-cluster",
        "AuthorizationPolicy": "AuthenticatedUser",
        "RateLimiterPolicy":   "GlobalIpLimit",
        "Match": {
          "Path": "/api/emr/{**catch-all}"
        }
      },

      "inventory-route": {
        "ClusterId":           "dental-cluster",
        "AuthorizationPolicy": "AuthenticatedUser",
        "RateLimiterPolicy":   "GlobalIpLimit",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      },

      "invoices-route": {
        "ClusterId":           "dental-cluster",
        "AuthorizationPolicy": "AuthenticatedUser",
        "RateLimiterPolicy":   "GlobalIpLimit",
        "Match": {
          "Path": "/api/invoices/{**catch-all}"
        }
      },

      "public-route": {
        "ClusterId":        "dental-cluster",
        "RateLimiterPolicy": "GlobalIpLimit",
        "Match": {
          "Path": "/api/public/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/news/{**catch-all}" }
        ]
      }
    },

    "Clusters": {
      "dental-cluster": {
        "LoadBalancingPolicy": "RoundRobin",

        "HttpRequest": {
          "Timeout": "00:00:30"
        },

        "HealthCheck": {
          "Active": {
            "Enabled":  true,
            "Interval": "00:00:10",
            "Timeout":  "00:00:05",
            "Policy":   "ConsecutiveFailures",
            "Path":     "/health"
          },
          "Passive": {
            "Enabled":           true,
            "Policy":            "TransportFailureRate",
            "ReactivationPeriod": "00:02:00"
          }
        },

        "Destinations": {
          "dental-1": {
            "Address": "https://localhost:7001",
            "Health":  "https://localhost:7001/health"
          },
          "dental-2": {
            "Address": "https://localhost:7002",
            "Health":  "https://localhost:7002/health"
          }
        }
      }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default":              "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp":                 "Information"
    }
  },
  "AllowedHosts": "*"
}
